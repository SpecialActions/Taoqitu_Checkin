name: Taoqitu Auto Checkin

on:
  schedule:
    - cron: '30 4,10 * * *'
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout code
        uses: actions/checkout@v3

      - name: Set up Python
        uses: actions/setup-python@v4
        with:
          python-version: '3.9'

      - name: Install dependencies
        run: pip install requests

      - name: Run Sign Script
        env:
          # 从 Secrets 读取 Token
          USER_TOKEN: ${{ secrets.USER_TOKEN }}
          
          ENABLE_OFFSET: ${{ secrets.ENABLE_OFFSET }}
          
        run: python sign.py
