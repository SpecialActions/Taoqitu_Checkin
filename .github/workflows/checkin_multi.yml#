name: Taoqitu Multi-Account Checkin

on:
  schedule:
    - cron: '30 0 * * *'  # 每天北京时间 08:30
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    permissions:
      actions: write
      contents: read

    steps:
      - name: Checkout code
        uses: actions/checkout@v4

      - name: Set up Python
        uses: actions/setup-python@v5
        with:
          python-version: '3.9'

      - name: Install dependencies
        run: pip install requests

      - name: Run Multi-Account Script
        env:
          ACCOUNTS: ${{ secrets.ACCOUNTS }}
          ENABLE_OFFSET: ${{ secrets.ENABLE_OFFSET }}
        run: python sign_multi.py

      - name: Delete old workflow runs
        env:
          GH_TOKEN: ${{ github.token }}
        run: |
          gh run list --limit 30 --json databaseId,conclusion | \
          jq -r '.[] | select(.conclusion=="success" or .conclusion=="skipped" or .conclusion=="cancelled") | .databaseId' | \
          xargs -I {} gh run delete {} || true
